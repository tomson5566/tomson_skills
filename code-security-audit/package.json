{
  "name": "@felipeoff/sonarqube-analyzer",
  "version": "1.1.0",
  "description": "Code security audit skill with Semgrep/builtin rules, dependency audit helpers, false-positive filtering, Skill package audit, and SonarQube integration",
  "main": "src/index.js",
  "bin": {
    "sonarqube-analyzer": "./scripts/analyze.js",
    "code-security-audit": "./scripts/semgrep_scan.js",
    "audit-skill": "./scripts/audit_skill.py"
  },
  "scripts": {
    "analyze": "node scripts/analyze.js",
    "test": "node scripts/smoke_test.js",
    "test:coverage": "jest --coverage",
    "lint": "eslint src scripts",
    "typecheck": "tsc --noEmit",
    "scan": "node scripts/semgrep_scan.js",
    "audit-skill": "python3 scripts/audit_skill.py",
    "filter": "python3 scripts/review_filter.py",
    "dep-audit": "bash scripts/dep_audit.sh",
    "dep-audit-java": "bash scripts/dep_audit_java.sh"
  },
  "keywords": [
    "ci-cd",
    "code-quality",
    "code-review",
    "dependency-audit",
    "false-positive-filtering",
    "openclaw",
    "openclaw-skill",
    "sast",
    "security",
    "semgrep",
    "skill-audit",
    "sonarqube",
    "static-analysis"
  ],
  "author": "FelipeOFF <felipeoliveireferreira@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/FelipeOFF/sonarqube-analyzer.git"
  },
  "bugs": {
    "url": "https://github.com/FelipeOFF/sonarqube-analyzer/issues"
  },
  "homepage": "https://github.com/FelipeOFF/sonarqube-analyzer#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "eslint": "^8.0.0",
    "jest": "^29.0.0"
  },
  "openclaw": {
    "skillId": "sonarqube-analyzer",
    "version": "1.0.0",
    "tools": [
      "sonar_get_issues",
      "sonar_analyze_and_suggest",
      "sonar_quality_gate"
    ],
    "config": {
      "schema": {
        "type": "object",
        "properties": {
          "sonarHostUrl": {
            "type": "string",
            "default": "http://127.0.0.1:9000",
            "description": "SonarQube server URL"
          },
          "sonarToken": {
            "type": "string",
            "description": "SonarQube authentication token"
          },
          "defaultProject": {
            "type": "string",
            "description": "Default project key to analyze"
          }
        }
      }
    }
  }
}
