### 2. AI Agent 函数调用
本技能属于QwenPaw生态标准技能，其他AI Agent可通过以下方式调用：

#### 函数定义
```typescript
// 函数名：code_security_audit
interface CodeSecurityAuditParams {
  /** 扫描类型：semgrep（本地扫描）/ sonarqube（SonarQube扫描） */
  scan_type: 'semgrep' | 'sonarqube';
  /** 要扫描的目录路径（semgrep扫描必填） */
  path?: string;
  /** 要过滤的风险等级，可选值：BLOCKER/CRITICAL/MAJOR/MINOR/INFO */
  severities?: string[];
  /** 是否自动修复可解决问题，默认false */
  auto_fix?: boolean;
  /** 报告输出路径，支持.md/.json格式 */
  output?: string;
  /** SonarQube项目Key（sonarqube扫描必填） */
  project_key?: string;
  /** PR编号，针对特定PR扫描（可选） */
  pr_number?: string;
  /** 是否生成修复建议，默认false */
  suggest_fixes?: boolean;
}

// 调用返回结构
interface CodeSecurityAuditResult {
  /** 扫描是否成功 */
  success: boolean;
  /** 扫描总问题数 */
  total_issues: number;
  /** 各等级问题统计 */
  severity_summary: {
    BLOCKER: number;
    CRITICAL: number;
    MAJOR: number;
    MINOR: number;
    INFO: number;
  };
  /** 问题详情列表 */
  issues?: Array<{
    file: string;
    line: number;
    severity: string;
    message: string;
    rule: string;
    fix: string;
    url: string;
  }>;
  /** 修复建议列表（开启suggest_fixes时返回） */
  suggestions?: Array<{
    file: string;
    line: number;
    issue: string;
    suggestion: string;
    auto_fixable: boolean;
  }>;
  /** 错误信息（扫描失败时返回） */
  error?: string;
}
```

#### 调用示例
```json
// 示例1：调用Semgrep扫描指定目录高危问题
{
  "name": "code_security_audit",
  "parameters": {
    "scan_type": "semgrep",
    "path": "/home/workspace/project",
    "severities": ["BLOCKER", "CRITICAL"],
    "output": "/home/workspace/security_report.md"
  }
}

// 示例2：调用SonarQube检查项目质量门
{
  "name": "code_security_audit",
  "parameters": {
    "scan_type": "sonarqube",
    "project_key": "my-project",
    "pr_number": "123",
    "suggest_fixes": true
  }
}
```

